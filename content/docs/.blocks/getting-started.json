{"version":1,"data":[{"type":"heading","props":{"level":1},"content":[{"type":"text","text":"Getting Started","styles":{}}],"children":[]},{"type":"paragraph","content":[{"type":"text","text":"Welcome to the project! This guide helps you get up and running quickly with the docs site.","styles":{}}],"children":[]},{"type":"heading","props":{"level":2},"content":[{"type":"text","text":"What’s included","styles":{}}],"children":[]},{"type":"bulletListItem","content":[{"type":"text","text":"A simple documentation structure in ","styles":{}},{"type":"text","text":"content/docs","styles":{"code":true}}],"children":[]},{"type":"bulletListItem","content":[{"type":"text","text":"Markdown and MDX pages for easy content creation","styles":{}}],"children":[]},{"type":"bulletListItem","content":[{"type":"text","text":"A lightweight site layout for getting started fast","styles":{}}],"children":[]},{"type":"heading","props":{"level":2},"content":[{"type":"text","text":"Install dependencies","styles":{}}],"children":[]},{"type":"paragraph","content":[{"type":"text","text":"First, install the project dependencies:","styles":{}}],"children":[]},{"type":"codeBlock","props":{"language":"bash"},"content":[{"type":"text","text":"npm install","styles":{}}],"children":[]},{"type":"heading","props":{"level":2},"content":[{"type":"text","text":"Run the development server","styles":{}}],"children":[]},{"type":"paragraph","content":[{"type":"text","text":"Start the local site and preview your documentation:","styles":{}}],"children":[]},{"type":"codeBlock","props":{"language":"bash"},"content":[{"type":"text","text":"npm run dev","styles":{}}],"children":[]},{"type":"paragraph","content":[{"type":"text","text":"Then open the URL shown in your terminal, usually ","styles":{}},{"type":"text","text":"http://localhost:3000","styles":{"code":true}},{"type":"text","text":".","styles":{}}],"children":[]},{"type":"heading","props":{"level":2},"content":[{"type":"text","text":"Add a new page","styles":{}}],"children":[]},{"type":"paragraph","content":[{"type":"text","text":"Create a new file in ","styles":{}},{"type":"text","text":"content/docs","styles":{"code":true}},{"type":"text","text":", for example:","styles":{}}],"children":[]},{"type":"codeBlock","props":{"language":"bash"},"content":[{"type":"text","text":"touch content/docs/new-guide.mdx","styles":{}}],"children":[]},{"type":"paragraph","content":[{"type":"text","text":"Then add a title and content using standard Markdown or MDX:","styles":{}}],"children":[]},{"type":"codeBlock","props":{"language":"mdx"},"content":[{"type":"text","text":"---\ntitle: New Guide\n---\n\n# New Guide\n\nWrite your content here.","styles":{}}],"children":[]},{"type":"heading","props":{"level":2},"content":[{"type":"text","text":"Next steps","styles":{}}],"children":[]},{"type":"bulletListItem","content":[{"type":"text","text":"Edit ","styles":{}},{"type":"text","text":"content/docs/index.mdx","styles":{"code":true}},{"type":"text","text":" to update the home page","styles":{}}],"children":[]},{"type":"bulletListItem","content":[{"type":"text","text":"Add additional guides under ","styles":{}},{"type":"text","text":"content/docs","styles":{"code":true}}],"children":[]},{"type":"bulletListItem","content":[{"type":"text","text":"Use MDX to include React components inside your docs if the site supports it","styles":{}}],"children":[]},{"type":"paragraph","content":[{"type":"text","text":"Happy writing!","styles":{}}],"children":[]}]}